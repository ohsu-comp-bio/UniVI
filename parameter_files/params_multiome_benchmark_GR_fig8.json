{
  "experiment": {
    "name":        "multiome_benchmark_GR_fig8",
    "figures":     ["GR-Fig8"],
    "description": "UniVI benchmark run against PyTorch and R tools on 10x PBMC Multiome (10x 2021a)",
    "accession":   "10x Genomics: 10k Human PBMCs, Multiome v1.0, Chromium X",
    "col":         "F"
  },

  "data": {
    "modalities":       ["rna", "atac"],
    "rna_filename":     "rna_multiome_pbmc_10x2021a.h5ad",
    "atac_filename":    "atac_multiome_pbmc_10x2021a.h5ad",
    "X_key_by_mod":     {"rna": "X", "atac": "obsm:X_lsi"},
    "split": {
      "train_frac":     0.80,
      "val_frac":       0.10,
      "test_frac":      0.10,
      "stratify_by":    "cell_type",
      "seed":           0,
      "n_train":        7704,
      "n_val":          963,
      "n_test":         964,
      "note":           "80/10/10; repeated CV across seeds; see Table S7 Col J"
    },
    "preprocessing": {
      "rna": {
        "n_hvg":                2000,
        "hvg_flavor":           "seurat_v3",
        "normalize_total":      10000,
        "log1p":                true,
        "scale":                true,
        "scale_max_value":      10,
        "fit_on_train":         true,
        "store_counts_layer":   "counts"
      },
      "atac": {
        "n_peaks":              107194,
        "tfidf":                true,
        "lsi_n_components":     101,
        "drop_lsi1":            true,
        "fit_on_train":         true,
        "store_counts_layer":   "counts",
        "store_lsi_obsm_key":   "X_lsi",
        "note":                 "Drop LSI1=Yes for benchmarking Cols J,K (Table S7 footnote)"
      }
    },
    "eval_labels":      ["cell_type"],
    "multi_seed":       true,
    "seeds":            [0, 1, 2]
  },

  "model": {
    "latent_dim":           30,
    "beta":                 1.35,
    "gamma":                3.75,
    "encoder_dropout":      0.10,
    "decoder_dropout":      0.05,
    "encoder_batchnorm":    true,
    "decoder_batchnorm":    false,
    "kl_anneal_start":      25,
    "kl_anneal_end":        75,
    "align_anneal_start":   45,
    "align_anneal_end":     95,
    "loss_mode":            "v1",
    "v1_recon":             "avg",
    "normalize_v1_terms":   true,
    "modalities": [
      {
        "name":             "rna",
        "encoder_hidden":   [512, 256, 128],
        "decoder_hidden":   [128, 256, 512],
        "likelihood":       "gaussian"
      },
      {
        "name":             "atac",
        "encoder_hidden":   [256, 128, 64],
        "decoder_hidden":   [64, 128, 256],
        "likelihood":       "gaussian",
        "note":             "Wider ATAC encoder/decoder vs other configs (Table S8 Col F)"
      }
    ]
  },

  "training": {
    "n_epochs":             200,
    "batch_size":           256,
    "lr":                   1e-3,
    "weight_decay":         1e-4,
    "device":               "cuda",
    "early_stopping":       true,
    "patience":             50,
    "best_epoch_warmup":    25,
    "log_every":            10,
    "note":                 "Short epoch budget for fair benchmark comparison across methods"
  }
}
